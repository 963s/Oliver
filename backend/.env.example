# Oliver Roos Friseur — Backend environment.
# Copy to `backend/.env` for local dev. In production (Electron build) all of
# these are set by `electron/main.mjs` before spawning the backend child.

# HTTP listening port for the Express API (same port the frontend talks to).
PORT=3000

# Absolute path to the SQLite file. In production it lives in:
#   ~/Library/Application Support/Oliver Roos Friseur/salon.db
DATABASE_PATH=./data/salon.db

# 64-hex-char secret for JWT-style staff session tokens.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST persist across launches — regenerating invalidates every session token.
# In production this is read from `userData/.auth_secret` (auto-created once).
AUTH_SECRET=replace-me-with-32-bytes-of-hex

# Either "development" (logger debug, dev affordances) or "production".
NODE_ENV=development

# When set, the backend serves the built frontend bundle from FRONTEND_PATH
# on the same port. Electron always sets SERVE_SPA=1 in production builds.
SERVE_SPA=0
# FRONTEND_PATH=../frontend/dist

# Directory for the rotating Winston log files.
# Defaults to `backend/data/logs/` if unset.
LOG_DIR=./data/logs

# ── Phase 2 — TSE / KassenSichV (leave empty in Phase 1) ───────────────────
# Local Epson-TSE printer (LAN) coordinates.
TSE_PRINTER_HOST=
TSE_PRINTER_PORT=9100
TSE_LAN_READ_MS=3000

# ── Phase 2 — Fiskaly cloud TSE (leave empty in Phase 1) ────────────────────
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_TSS_ID=
