{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oliver Roos FRISUREN",
  "version": "0.1.0",
  "identifier": "com.oliverroos.pos",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -w @oliver-roos/frontend",
    "beforeBuildCommand": "cross-env VITE_API_BASE=http://127.0.0.1:3000 VITE_EMBEDDED_DESKTOP=1 npm run build -w @oliver-roos/frontend"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Oliver Roos FRISUREN",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["underWindowBackground"]
        },
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; img-src 'self' asset: http: https: data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": ["embedded-backend/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
